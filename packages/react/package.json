{
  "name": "@consentloop/react",
  "version": "0.1.0",
  "description": "React bindings for ConsentLoop — provider, hooks and <ConsentGate> for the fastest cookie consent on the web.",
  "license": "FSL-1.1-MIT",
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node build.mjs && tsc -p tsconfig.build.json",
    "prepack": "npm run build"
  },
  "keywords": [
    "cookie-consent",
    "react",
    "gdpr",
    "consent-management",
    "consentloop"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kocsmy/ConsentLoop.git",
    "directory": "packages/react"
  },
  "peerDependencies": {
    "react": ">=17"
  },
  "dependencies": {
    "consentloop": "workspace:^"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "esbuild": "^0.24.0",
    "react": "^18.3.1",
    "typescript": "^5.6.0"
  }
}
