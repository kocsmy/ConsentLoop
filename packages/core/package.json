{
  "name": "consentloop",
  "version": "0.1.1",
  "description": "The fastest cookie consent banner for the web — a source-available CMP. Zero dependencies, zero layout shift, ~1.5 KB loader. Google Consent Mode v2, GDPR & CCPA presets, script & embed gating, per-service consent, 58 languages, headless mode.",
  "homepage": "https://consentloop.io",
  "bugs": {
    "url": "https://github.com/kocsmy/ConsentLoop/issues"
  },
  "license": "FSL-1.1-MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "unpkg": "./dist/consentloop.iife.min.js",
  "jsdelivr": "./dist/consentloop.iife.min.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./min": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.min.js",
      "default": "./dist/index.min.js"
    },
    "./iife": "./dist/consentloop.iife.min.js",
    "./loader": "./dist/consentloop.loader.min.js",
    "./schema.json": "./schema.json",
    "./locales/*": "./locales/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "schema.json",
    "locales",
    "README.md"
  ],
  "scripts": {
    "build": "node build.mjs && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "keywords": [
    "cookie-consent",
    "cookie-banner",
    "cookie-consent-banner",
    "consent-management",
    "consent-management-platform",
    "cmp",
    "gdpr",
    "ccpa",
    "dsgvo",
    "google-consent-mode",
    "consent-mode-v2",
    "cookie-notice",
    "cookie-law",
    "privacy",
    "cookies",
    "consent",
    "script-gating",
    "consentloop"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/kocsmy/ConsentLoop.git",
    "directory": "packages/core"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "jsdom": "^25.0.0"
  }
}
